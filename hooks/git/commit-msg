#!/usr/bin/env bash
# ABOUTME: commit-msg git hook dispatcher — runs all commit-msg check scripts in order
# ABOUTME: Called by git with the commit message file path as $1; blocks if any check fails

set -uo pipefail

# Resolve symlink to find the real hooks/git/ directory
if [[ -L "$0" ]]; then
    _link_target="$(readlink "$0")"
    if [[ "$_link_target" = /* ]]; then
        HOOK_DIR="$(dirname "$_link_target")"
    else
        HOOK_DIR="$(cd "$(dirname "$0")/$(dirname "$_link_target")" && pwd)"
    fi
else
    HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
fi
CHECKS_DIR="$HOOK_DIR/checks"

# Commit message file is passed as first argument by git
COMMIT_MSG_FILE="${1:-}"

# Run a check script if it exists; accumulate failures (run-all, not fail-fast)
run_check() {
    local script="$1"
    shift
    [[ -f "$script" ]] || return 0
    [[ -x "$script" ]] || chmod +x "$script"
    "$script" "$@"
}

exit_code=0

run_check "$CHECKS_DIR/commit-message.sh" "$COMMIT_MSG_FILE" || exit_code=$?

exit "$exit_code"
